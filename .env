# A股盯盘与复盘系统 — 敏感配置
# 复制此文件为 .env 并填入实际值

# Tushare Pro Token（选填，akshare 可替代大部分功能）
TUSHARE_TOKEN=your_token_here

# 默认数据源：akshare / tushare
DATA_PROVIDER_DEFAULT=akshare

# 报告邮件推送（选填）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_password
REPORT_EMAIL_TO=your_email@qq.com
